# Banco de dados (Supabase PostgreSQL — connection string direto)
DATABASE_URL=postgresql://postgres:SENHA@db.PROJECT_REF.supabase.co:5432/postgres

# Chave de serviço do Supabase (Settings > API > service_role)
# Usada para upload/download/delete de arquivos no Storage
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional — auto-derivada do DATABASE_URL se omitida
# SUPABASE_URL=https://PROJECT_REF.supabase.co

# JWT secret para autenticação interna
SECRET_KEY=troque-por-uma-string-longa-e-aleatoria
