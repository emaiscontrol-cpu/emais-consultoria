        <!-- RODAPÉ — FLUXOS E CONVENCOES                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <mxCell id="155" value="DEPLOY:  ①  release.ps1 (bump versao + npm build + git push) → GitHub → ②  Actions dispara runner → git pull + Restart-Service → uvicorn recarrega ~30s
USO:  Electron / Navegador → ③  ngrok HTTPS → FastAPI :8000 → SQLite → ④  JSON → React SPA
CONVENCOES:  agrupamento = Aglutinacao (pode repetir)  |  variavel_dre = variavel unica em formulas DRE  |  formula text = eval() com namespace byToken  |  hierarquia DRE = posicional por ordem" style="text;html=1;strokeColor=#E87722;fillColor=#fff8f0;rounded=1;fontFamily=Segoe UI;fontSize=10;align=left;spacingLeft=12;spacingRight=12;" vertex="1" parent="1"><mxGeometry x="10" y="1608" width="1740" height="56" as="geometry"/></mxCell>
