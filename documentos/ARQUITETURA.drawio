        <!-- ── MOTOR DRE ──────────────────────────────────────────────── -->
        <mxCell id="210" value="Motor DRE  —  dre_engine.py" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ede7f6;strokeColor=#7B1FA2;fontFamily=Segoe UI;fontStyle=1;fontSize=12;" vertex="1" parent="105"><mxGeometry x="444" y="450" width="296" height="28" as="geometry"/></mxCell>

        <mxCell id="211" value="Pass 1  —  TT sem fórmula:
  stored_total ≠ 0 → usa valor importado ERP
  stored_total = 0 → soma ANs posicionais
  → byToken[variavel_dre] = {mes: valor}" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f3e5f5;strokeColor=#9c27b0;fontFamily=Segoe UI;fontStyle=0;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="105"><mxGeometry x="444" y="486" width="296" height="68" as="geometry"/></mxCell>

        <mxCell id="212" value="Pass 2  —  TT com fórmula:
  item.formula (texto) ← prioridade
  eval(formula, {__builtins__:{}}, namespace)
  Suporte: + - * / () numeros constantes
  → byToken[variavel_dre] = resultado" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f3e5f5;strokeColor=#9c27b0;fontFamily=Segoe UI;fontStyle=0;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="105"><mxGeometry x="444" y="562" width="296" height="74" as="geometry"/></mxCell>

        <mxCell id="213" value="⚠  Regras DRE:
variavel_dre → UNICO por linha TT/RES (nome da variavel em formulas)
agrupamento → Aglutinacao (pode repetir; uso contabil/futuro)
Hierarquia posicional: AN pertence ao ultimo TT acima na ordem
formula text: 'RECEITA - DED_TOTAL' | eval com namespace byToken" style="text;html=1;strokeColor=#7B1FA2;fillColor=#f9f0ff;rounded=1;fontFamily=Segoe UI;fontSize=9;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="105"><mxGeometry x="444" y="644" width="296" height="72" as="geometry"/></mxCell>

